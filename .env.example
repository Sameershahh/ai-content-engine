# ─────────────────────────────────────────────
#  AI Content Synthesis Engine — Environment
# ─────────────────────────────────────────────

# Google Gemini (free tier: gemini-2.0-flash)
GEMINI_API_KEY=your_gemini_api_key_here

# SiliconFlow (free tier image generation)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Google Drive
GDRIVE_CREDENTIALS_JSON=credentials.json   # path to OAuth2 / Service Account JSON
GDRIVE_ROOT_FOLDER_ID=1aBcDeFqRsTuVwXyZ

# ── System ───────
# Set this to your local ImageMagick 'magick.exe' path
IMAGEMAGICK_BINARY=D:\Program\ImageMagick-7.1.2-Q16\magick.exe

# App config
APP_ENV=development
LOG_LEVEL=INFO
OUTPUT_DIR=outputs
TEMP_DIR=temp

# Scraping targets (comma-separated subreddits)
REDDIT_SUBREDDITS=technology,artificial,MachineLearning,marketing
TRENDS_GEO=US
